{
  "files.associations": {
    "SKILL.md": "markdown"
  },
  "search.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/dist": true
  },
  "terminal.integrated.cwd": "${workspaceFolder}",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "git.ignoreLimitWarning": true
}
